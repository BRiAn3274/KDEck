{
  "name": "kdeck",
  "version": "0.5.1",
  "packageManager": "pnpm@9.15.9",
  "description": "KDEck SteamOS game mode panel for KDE Connect clipboard and file transfer",
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w",
    "test": "python -m unittest discover -s tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BRiAn3274/KDEck.git"
  },
  "keywords": [
    "decky",
    "plugin",
    "kde-connect",
    "clipboard",
    "file-transfer",
    "steam-deck",
    "deck"
  ],
  "author": "RainsListener",
  "license": "BSD-3-Clause",
  "bugs": {
    "url": "https://github.com/BRiAn3274/KDEck/issues"
  },
  "homepage": "https://github.com/BRiAn3274/KDEck#readme",
  "devDependencies": {
    "@decky/rollup": "^1.0.2",
    "@decky/ui": "^4.11.0",
    "@rollup/rollup-linux-x64-musl": "^4.53.3",
    "@types/react": "19.1.1",
    "@types/react-dom": "19.1.1",
    "@types/webpack": "^5.28.5",
    "rollup": "^4.53.3",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "@decky/api": "^1.1.3",
    "react-icons": "^5.3.0",
    "tslib": "^2.7.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    }
  }
}
